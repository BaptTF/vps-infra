{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "enabledManagers": [
    "kustomize",
    "argocd",
    "kubernetes",
    "helm-values",
    "custom.regex"
  ],
  "argocd": {
    "managerFilePatterns": ["/apps/.+\\.yaml$/"]
  },
  "kubernetes": {
    "managerFilePatterns": ["/(^|/)(system|workloads)/.+\\.ya?ml$/"]
  },
  "helm-values": {
    "managerFilePatterns": ["/(^|/)(system|workloads)/.+/values\\.ya?ml$/"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Full image:repo:tag strings in Helm values (e.g. Velero plugins)",
      "managerFilePatterns": ["/(^|/)(system|workloads)/.+/values\\.ya?ml$/"],
      "matchStrings": [
        "\\simage:\\s*[\"']?(?<depName>[^\\s\"'@]+)\\:(?<currentValue>[^\\s\"'@]+)[\"']?"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "CloudNativePG Cluster imageName (not covered by kubernetes manager)",
      "managerFilePatterns": ["/(^|/)(system|workloads)/.+\\.ya?ml$/"],
      "matchStrings": [
        "imageName:\\s*[\"']?(?<depName>[^\\s\"'@]+):(?<currentValue>[^\\s\"'@]+)(?:@(?<currentDigest>sha256:[a-f0-9]+))?[\"']?"
      ],
      "datasourceTemplate": "docker",
      "versioningTemplate": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)-(?<patch>\\d+)\\.(?<build>\\d+)\\.(?<revision>\\d+)$",
      "autoReplaceStringTemplate": "imageName: {{{depName}}}:{{{newValue}}}{{#if newDigest}}@{{{newDigest}}}{{/if}}"
    }
  ],
  "ignorePaths": [
    "argocd-bootstrap.yaml",
    "disable-apps/**",
    "**/.argocd-source-*"
  ],
  "semanticCommits": "enabled",
  "semanticCommitType": "build",
  "packageRules": [
    {
      "description": "First-party images: owned by ArgoCD Image Updater (direct commits to main)",
      "matchDatasources": ["docker"],
      "matchPackageNames": [
        "/^ghcr\\.io\\/bapttf\\//",
        "/^ghcr\\.io\\/rjullien\\//"
      ],
      "enabled": false
    },
    {
      "description": "LLDAP: stay on alpine-rootless semver tags (ignore date-based tags)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/lldap/lldap"],
      "versioning": "regex:^v?(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?<compatibility>-alpine-rootless)$"
    },
    {
      "description": "filebrowser: only consider -stable tags (ignore -beta)",
      "matchDatasources": ["docker"],
      "matchPackageNames": ["ghcr.io/gtsteffaniak/filebrowser"],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)\\.(?<patch>\\d+)(?<compatibility>-stable)$"
    },
    {
      "description": "Label major updates for manual review",
      "matchManagers": [
        "kustomize",
        "argocd",
        "kubernetes",
        "helm-values",
        "custom.regex"
      ],
      "matchUpdateTypes": ["major"],
      "labels": ["major-update"]
    }
  ]
}
